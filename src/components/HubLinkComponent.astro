---
export interface Props {
  redirectTo: string;
}

const { redirectTo } = Astro.props;
---

<a class="btn" href={redirectTo} target="_blank" rel="noopener noreferrer">
  <span class="btn__background"></span>
  <span class="btn__foreground">
    <i>
      <slot name="icon" />
    </i>
    <span>
      <slot />
    </span>
  </span>
</a>

<style lang="scss">
  .btn {
    text-decoration: none;
    position: relative;
    width: 100%;
    height: 56px;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(10, 12, 20, 0.52);
    color: rgba(255, 255, 255, 0.9);
    cursor: pointer;
    outline: none;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: transform 220ms cubic-bezier(0.2, 0.9, 0.2, 1),
      box-shadow 220ms ease, border-color 220ms ease;

    &__background {
      position: absolute;
      inset: 0;
      background: linear-gradient(
          110deg,
          color-mix(in oklab, var(--primary-color) 55%, black 20%),
          rgba(0, 0, 0, 0)
        ),
        radial-gradient(
          800px 120px at 30% 50%,
          color-mix(in oklab, var(--primary-color) 35%, transparent),
          transparent 60%
        );
      transform: translateX(-100%);
      transition: transform 640ms cubic-bezier(0.2, 0.9, 0.2, 1);
      opacity: 0.9;
    }

    &__foreground {
      position: relative;
      height: 100%;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0 1rem;
      font-size: 0.875rem;

      i {
        width: 30px;
        aspect-ratio: 1 / 1;
        border-radius: 0.75rem;
        display: grid;
        place-items: center;
        background: var(--accent-light-color);
        border: 1px solid var(--accent-color);
        transition: transform 320ms cubic-bezier(0.2, 0.9, 0.2, 1);
        font-style: normal;
      }

      span {
        font-weight: 600;
        letter-spacing: 0.2px;
        transform: translateX(-0.25rem);
        opacity: 0.85;
        transition: transform 320ms cubic-bezier(0.2, 0.9, 0.2, 1),
          opacity 220ms ease;
      }
    }

    &::before {
      content: '';
      position: absolute;
      inset: -2px;
      background: linear-gradient(
        120deg,
        transparent 10%,
        rgba(255, 255, 255, 0.16) 18%,
        transparent 26%
      );
      opacity: 0;
      transform: translateX(-40%);
      transition: opacity 180ms ease,
        transform 560ms cubic-bezier(0.2, 0.9, 0.2, 1);
      pointer-events: none;
    }

    &:hover {
      transform: translateY(-2px);
      border-color: color-mix(
        in oklab,
        var(--primary-color) 45%,
        rgba(255, 255, 255, 0.15)
      );
      box-shadow: 0 18px 42px rgba(0, 0, 0, 0.55),
        0 0 0 4px
          color-mix(in oklab, var(--primary-color) 18%, transparent),
        0 0 30px
          color-mix(in oklab, var(--primary-color) 26%, transparent);

      .btn__background {
        transform: translateX(0%);
      }

      .btn__foreground i {
        transform: rotate(-6deg) scale(1.04);
      }

      .btn__foreground span {
        transform: translateX(0);
        opacity: 0.98;
      }

      &::before {
        opacity: 1;
        transform: translateX(40%);
      }
    }

    &:active {
      transform: translateY(0) scale(0.99);
    }
  }
</style>