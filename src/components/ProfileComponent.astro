---
import { Image } from 'astro:assets';

import meImage from '@/assets/me.webp';
---

<section class="profile">
		<Image
			class="profile__image"
			src={meImage}
			alt="Foto de perfil de Prophet Code"
			draggable="false"
		/>
	</section>

  <style lang="scss">
	@use './../styles/tools' as tools;

	.profile {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
		--thumb-size: 120px;
		
		@include tools.respond-to('md') {
			--thumb-size: 140px;
		}
	
		&__image {
			position: relative;
			width: var(--thumb-size);
			height: var(--thumb-size);
			object-fit: cover;
			border: 2px solid var(--secondary-color);
			border-radius: 50%;
			corner-shape: squircle;
		}

		&::before {
			content: '';
			position: absolute;
			display: block;
			top: 0;
			background-color: var(--neutral-black-color);
			width: var(--thumb-size);
			aspect-ratio: 1 / 1;
			transform: scale(1.2);
			border-radius: 50%;
			corner-shape: squircle;
		}
	}
</style>