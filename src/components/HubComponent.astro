---
import { Image } from 'astro:assets';

import { ACADEMY_URL, PORTFOLIO_URL, BUYME_A_COFFEE_URL, TALLY_URL } from '@/constants/prophet-code-links';
import bitmojiHeroeImage from '@/assets/bitmoji-heroe.webp';
import HubLinkComponent from '@/components/HubLinkComponent.astro';

const hubLinks = [
	{ icon: '🎓', text: 'Prophet Code Academy — Cursos', redirectTo: ACADEMY_URL },
	{ icon: '💼', text: 'Mi portafolio — Trayectoria', redirectTo: PORTFOLIO_URL },
	{ icon: '☕', text: 'Cómprame un café — Donaciones', redirectTo: BUYME_A_COFFEE_URL },
	{ icon: '📩', text: 'Contacto — Escríbeme', redirectTo: TALLY_URL },
];
---

<Image
  class="content-bitmoji"
  src={bitmojiHeroeImage}
  alt="Bitmoji de Alexander Avila"
	draggable="false"
/>

<article class="content-hub">
	{
		hubLinks.map(({ icon, text, redirectTo }) => (
			<HubLinkComponent redirectTo={redirectTo}>
				<span slot="icon">{icon}</span>
				{text}
			</HubLinkComponent>
		))
	}
</article>

<style lang="scss">
	@use '../styles/tools' as tools;

	.content {
		&-bitmoji {
			margin-block-start: 1rem;
			max-height: 150px;
			width: auto;
		}

		&-hub {
			display: flex;
			flex-direction: column;
			gap: 1rem;
			margin-top: -1.25rem;
			width: 100%;

			@include tools.respond-to('md') {
				width: 95%;
			}

			@include tools.respond-to('lg') {
				width: 90%;
			}
		}
	}
</style>