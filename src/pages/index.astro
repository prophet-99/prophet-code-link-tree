---
import Layout from '@/layouts/Layout.astro';
import ProfileComponent from '@/components/ProfileComponent.astro';
import HubComponent from '@/components/HubComponent.astro';
import SocialNetworksComponent from '@/components/SocialNetworksComponent.astro';
---

<Layout>
	<ProfileComponent />

	<section class="content">
		<h1 class="content__title">Alexander Avila</h1>
		<p class="content__description">
			Sr. Software Engineer | Content Creator | Tech Enthusiast
		</p>

		<SocialNetworksComponent />
		
		<HubComponent />
	</section>

	<footer class="developer-credit">
		Desarrollado por Prophet Code 😾
	</footer>
</Layout>

<style lang="scss">
	@use '../styles/tools' as tools;

	.content {
		margin-block-start: 1rem;
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
		
		@include tools.respond-to('sm') {
			max-width: 450px;
		}

		&__title {
			text-align: center;
			font-size: 2rem;
			font-weight: 600;
		}

		&__description {
			margin-block-start: 0.5rem;
			text-align: center;
			color: var(--secondary-color);
		}
	}

	.developer-credit {
		margin-block-start: 2rem;
		text-align: center;
		font-size: 0.75rem;
		font-weight: 600;
		color: #8e8e8e;
	}
</style>